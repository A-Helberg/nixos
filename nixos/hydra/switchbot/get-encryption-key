#!/usr/bin/env python3
"""
Retrieve the encryption key for a SwitchBot Lock from the SwitchBot cloud.

Usage:
  ./get-encryption-key <MAC_ADDRESS> <SWITCHBOT_USERNAME>

The MAC address can be found in the SwitchBot app under the device settings.
You will be prompted for your SwitchBot account password.
"""

import getpass
import sys

from switchbot import SwitchbotLock


def main() -> None:
    if len(sys.argv) < 3:
        print(f"Usage: {sys.argv[0]} <MAC_ADDRESS> <SWITCHBOT_USERNAME>")
        sys.exit(1)

    mac = sys.argv[1]
    username = sys.argv[2]
    password = getpass.getpass("SwitchBot account password: ")

    try:
        result = SwitchbotLock.retrieve_encryption_key(mac, username, password)
    except RuntimeError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    print(f"Key ID:         {result['key_id']}")
    print(f"Encryption key: {result['encryption_key']}")
    print()
    print("Pass these to switchbot-lock with -k / -e, or set:")
    print(f"  export SWITCHBOT_KEY_ID={result['key_id']}")
    print(f"  export SWITCHBOT_ENC_KEY={result['encryption_key']}")


if __name__ == "__main__":
    main()
